generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  password      String?
  role          String    @default("ADMIN")
  roleId        String?   @map("role_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  accounts         Account[]
  sessions         Session[]
  activityLogs     ActivityLog[]
  userPermissions  UserPermission[]
  systemRole        Role?     @relation(fields: [roleId], references: [id])

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verificationtokens")
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  action    String
  details   String?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("activity_logs")
}

model Section {
  id          String   @id @default(cuid())
  name        String   @unique
  title       String
  type        String
  content     String?
  isVisible   Boolean  @default(true) @map("is_visible")
  order       Int      @default(0)
  navLabel    String?  @map("nav_label")
  showInNav   Boolean  @default(true) @map("show_in_nav")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("sections")
}

model Project {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String
  content     String?
  contentType String   @default("standard") @map("content_type") // standard, case-study, tutorial, portfolio, research
  image       String?
  images      String?
  githubUrl   String?  @map("github_url")
  demoUrl     String?  @map("demo_url")
  techStack   String?  @map("tech_stack")
  featured    Boolean  @default(false)
  isPublished Boolean  @default(true) @map("is_published")
  order       Int      @default(0)
  views       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("projects")
}

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String?
  content     String
  coverImage  String?  @map("cover_image")
  tags        String?
  isPublished Boolean  @default(false) @map("is_published")
  publishedAt DateTime? @map("published_at")
  views       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("blog_posts")
}

model Experience {
  id          String   @id @default(cuid())
  company     String
  position    String
  location    String?
  startDate   DateTime @map("start_date")
  endDate     DateTime? @map("end_date")
  isCurrent   Boolean  @default(false) @map("is_current")
  description String
  highlights  String?
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("experiences")
}

model Education {
  id          String   @id @default(cuid())
  institution String
  degree      String
  field       String?
  location    String?
  startDate   DateTime @map("start_date")
  endDate     DateTime? @map("end_date")
  isCurrent   Boolean  @default(false) @map("is_current")
  description String?
  gpa         String?
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("education")
}

model Certification {
  id           String   @id @default(cuid())
  name         String
  organization String
  issueDate    DateTime @map("issue_date")
  expiryDate   DateTime? @map("expiry_date")
  credentialId String?  @map("credential_id")
  credentialUrl String? @map("credential_url")
  image        String?
  order        Int      @default(0)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("certifications")
}

model SkillCategory {
  id          String    @id @default(cuid())
  name        String    @unique
  label       String
  order       Int       @default(0)
  isVisible   Boolean   @default(true) @map("is_visible")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  skills      Skill[]

  @@map("skill_categories")
}

model Skill {
  id          String       @id @default(cuid())
  name        String
  categoryId  String?      @map("category_id")
  category    SkillCategory? @relation(fields: [categoryId], references: [id])
  proficiency Int          @default(80)
  icon        String?
  isVisible   Boolean      @default(true) @map("is_visible")
  order       Int          @default(0)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  @@map("skills")
}

model Resume {
  id          String   @id @default(cuid())
  fileName    String   @map("file_name")
  fileUrl     String   @map("file_url")
  fileSize    Int      @map("file_size")
  isActive    Boolean  @default(true) @map("is_active")
  uploadedAt  DateTime @default(now()) @map("uploaded_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("resumes")
}

model Theme {
  id              String   @id @default(cuid())
  name            String   @default("default")
  primaryColor    String   @default("#3b82f6") @map("primary_color")
  secondaryColor  String   @default("#8b5cf6") @map("secondary_color")
  accentColor     String   @default("#10b981") @map("accent_color")
  backgroundColor String   @default("#0f172a") @map("background_color")
  surfaceColor    String   @default("#1e293b") @map("surface_color")
  textColor       String   @default("#f8fafc") @map("text_color")
  mutedColor      String   @default("#64748b") @map("muted_color")
  fontFamily      String   @default("inter") @map("font_family")
  isDarkMode      Boolean  @default(true) @map("is_dark_mode")
  animationIntensity String @default("medium") @map("animation_intensity")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("themes")
}

model SocialLink {
  id        String   @id @default(cuid())
  platform  String
  url       String
  icon      String?
  isVisible Boolean  @default(true) @map("is_visible")
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("social_links")
}

model Analytics {
  id        String   @id @default(cuid())
  page      String
  visitorId String   @map("visitor_id")
  sessionId String   @map("session_id")
  userAgent String?  @map("user_agent")
  referrer  String?
  country   String?
  city      String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([page])
  @@index([createdAt])
  @@map("analytics")
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String?
  message   String
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("contact_messages")
}

model PersonalInfo {
  id          String   @id @default(cuid())
  firstName   String   @map("first_name")
  lastName    String   @map("last_name")
  title       String
  tagline     String?
  bio         String
  email       String
  phone       String?
  location    String?
  avatar      String?
  bannerImage String?  @map("banner_image")
  aboutImage  String?  @map("about_image")
  interests   String?
  resumeUrl   String?  @map("resume_url")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("personal_info")
}

model CustomQA {
  id          String   @id @default(cuid())
  question    String   @unique
  answer      String
  category    String   @default("General")
  keywords    String?
  isActive    Boolean  @default(true) @map("is_active")
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("custom_qa")
}

model SiteSettings {
  id              String   @id @default(cuid())
  aiEnabled       Boolean  @default(true) @map("ai_enabled")
  aiMode          String   @default("hybrid") // "hybrid" = AI + manual, "manual" = only admin answers
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}

model CurrentlyTracking {
  id          String   @id @default(cuid())
  title       String
  category    String   // "M&A", "IPO", "Macro", "Capital Markets", "Regulation", etc.
  date        DateTime @default(now())
  commentary  String?
  status      String   @default("Watching") // "Watching", "Developing", "Closed"
  isVisible   Boolean  @default(true) @map("is_visible")
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("currently_tracking")
}

// ============================================
// MODULE 1: Dynamic Page Builder
// ============================================

model CustomPage {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?
  content     String?
  sections    PageSection[]
  tabs        PageTab[]
  isPublished Boolean  @default(false) @map("is_published")
  showInNav   Boolean  @default(false) @map("show_in_nav")
  navLabel    String?  @map("nav_label")
  navOrder    Int      @default(0) @map("nav_order")
  metaTitle   String?  @map("meta_title")
  metaDescription String? @map("meta_description")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("custom_pages")
}

model PageTab {
  id          String    @id @default(cuid())
  pageId      String    @map("page_id")
  page        CustomPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  title       String
  slug        String?
  icon        String?
  order       Int       @default(0)
  isVisible   Boolean   @default(true) @map("is_visible")
  sections    PageSection[]
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("page_tabs")
}

model PageSection {
  id          String    @id @default(cuid())
  pageId      String    @map("page_id")
  page        CustomPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  tabId       String?   @map("tab_id")
  tab         PageTab?  @relation(fields: [tabId], references: [id], onDelete: Cascade)
  sectionType String    @map("section_type") // hero, about, projects, skills, etc.
  title       String?
  content     String?
  order       Int       @default(0)
  layoutStyle String    @default("default") @map("layout_style") // grid, list, carousel, masonry, split-view
  isVisible   Boolean   @default(true) @map("is_visible")
  settings    String?   // JSON string for additional settings
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("page_sections")
}

// ============================================
// MODULE 3: AI Knowledge Base Manager
// ============================================

model KnowledgeCategory {
  id          String          @id @default(cuid())
  name        String          @unique
  description String?
  color       String          @default("#3b82f6")
  icon        String?
  parentId    String?         @map("parent_id")
  parent      KnowledgeCategory? @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    KnowledgeCategory[] @relation("CategoryHierarchy")
  documents   KnowledgeDocument[]
  order       Int             @default(0)
  isVisible   Boolean         @default(true) @map("is_visible")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  @@map("knowledge_categories")
}

model KnowledgeDocument {
  id            String   @id @default(cuid())
  title         String
  content       String
  summary       String?
  documentType  String   @default("text") @map("document_type") // pdf, docx, xlsx, text, markdown, url
  fileUrl       String?  @map("file_url")
  fileName      String?  @map("file_name")
  fileSize      Int?     @map("file_size")
  sourceUrl     String?  @map("source_url")
  tags          String?  // Comma-separated tags
  categoryId    String?  @map("category_id")
  category      KnowledgeCategory? @relation(fields: [categoryId], references: [id])
  embeddings    KnowledgeEmbedding[]
  isIndexed     Boolean  @default(false) @map("is_indexed")
  embeddingId   String?  @map("embedding_id")
  views         Int      @default(0)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([categoryId])
  @@index([documentType])
  @@map("knowledge_documents")
}

model KnowledgeEmbedding {
  id           String   @id @default(cuid())
  documentId   String   @map("document_id")
  document     KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  content      String
  embedding    String   // Stored as JSON string of numbers
  chunkIndex   Int      @default(0) @map("chunk_index")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([documentId])
  @@map("knowledge_embeddings")
}

// ============================================
// MODULE 4: Analytics Dashboard (Enhanced)
// ============================================

model AnalyticsEvent {
  id          String   @id @default(cuid())
  eventType   String   @map("event_type") // pageview, click, form_submit, ai_query
  page        String
  visitorId   String   @map("visitor_id")
  sessionId   String   @map("session_id")
  userAgent   String?  @map("user_agent")
  referrer    String?
  country     String?
  city        String?
  deviceType  String?  @map("device_type") // mobile, desktop, tablet
  browser     String?
  os          String?
  duration    Int?     // Session duration in seconds
  metadata    String?  // JSON string for additional event data
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([eventType])
  @@index([createdAt])
  @@index([visitorId])
  @@map("analytics_events")
}

model DailyStats {
  id              String   @id @default(cuid())
  date            DateTime @unique
  pageViews       Int      @default(0) @map("page_views")
  uniqueVisitors  Int      @default(0) @map("unique_visitors")
  sessions        Int      @default(0)
  avgDuration     Float    @default(0) @map("avg_duration")
  bounceRate      Float    @default(0) @map("bounce_rate")
  aiQueries       Int      @default(0) @map("ai_queries")
  contactSubmits  Int      @default(0) @map("contact_submits")
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("daily_stats")
}

// ============================================
// MODULE 5: AI Control Panel
// ============================================

model AIConfiguration {
  id              String   @id @default(cuid())
  name            String   @default("default")
  provider        String   @default("openai") // openai, anthropic, deepseek, mistral, ollama
  model           String   @default("gpt-4o")
  temperature     Float    @default(0.7)
  maxTokens       Int      @default(2048) @map("max_tokens")
  systemPrompt    String?  @map("system_prompt")
  personalityTraits String? @map("personality_traits")
  rateLimitPerHour Int     @default(100) @map("rate_limit_per_hour")
  featuresEnabled  String   @default("chat,search,knowledge") @map("features_enabled")
  isActive        Boolean  @default(true) @map("is_active")
  apiKey          String?  // Encrypted
  apiEndpoint     String?  @map("api_endpoint")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("ai_configurations")
}

// ============================================
// MODULE 6: Content Scheduling System
// ============================================

model ScheduledContent {
  id              String    @id @default(cuid())
  contentType     String    @map("content_type") // project, blog, research, etc.
  contentId       String    @map("content_id")
  title           String
  action          String    @default("publish") // publish, unpublish, archive
  scheduledFor    DateTime  @map("scheduled_for")
  timezone        String    @default("UTC")
  isExecuted      Boolean   @default(false) @map("is_executed")
  executedAt      DateTime? @map("executed_at")
  recurrence      String?   // none, daily, weekly, monthly
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([scheduledFor])
  @@index([isExecuted])
  @@map("scheduled_content")
}

// ============================================
// MODULE 7: Navigation Tabs (Dynamic)
// ============================================

model NavigationTab {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  icon        String?  // Icon name (e.g., 'book', 'chart', 'file')
  contentType String   @default("text") // text, qa, custom, link
  content     String?  // JSON string for content (text content, custom data, etc.)
  externalUrl String?  @map("external_url") // For contentType = link
  order       Int      @default(0)
  isVisible   Boolean  @default(true) @map("is_visible")
  isActive    Boolean  @default(true) @map("is_active")
  isPublished Boolean  @default(false) @map("is_published")
  subtitle    String?  // Section subtitle
  navLabel    String?  @map("nav_label") // Label to show in navigation
  sections    NavSection[]
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("navigation_tabs")
}

model NavSection {
  id          String    @id @default(cuid())
  navTabId    String    @map("nav_tab_id")
  navTab      NavigationTab @relation(fields: [navTabId], references: [id], onDelete: Cascade)
  title       String?
  subtitle    String?
  sectionType String    @default("custom") @map("section_type") // text, heading, image, cards, table, columns, divider, embed, custom-html
  content     String?   // JSON string for content blocks
  order       Int       @default(0)
  layoutStyle String    @default("full-width") @map("layout_style") // full-width, centered, two-column, grid, split
  isVisible   Boolean   @default(true) @map("is_visible")
  // Styling options
  backgroundColor String? @map("background_color")
  textColor      String? @map("text_color")
  accentColor    String? @map("accent_color")
  paddingTop    String?  @map("padding_top") // e.g., "2rem", "md", "lg"
  paddingBottom String?  @map("padding_bottom")
  marginTop     String?  @map("margin_top")
  marginBottom  String?  @map("margin_bottom")
  fontFamily    String?  @map("font_family")
  customCss    String?  @map("custom_css")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@map("nav_sections")
}

// ============================================
// MODULE 7: Version History and Rollback
// ============================================

model VersionHistory {
  id          String   @id @default(cuid())
  entityType  String   @map("entity_type") // page, section, project, blog, settings, etc.
  entityId    String   @map("entity_id")
  version     Int      @default(1)
  data        String   // JSON string of the content at this version
  changes     String?  // JSON string describing what changed
  createdBy   String?  @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  isMilestone Boolean  @default(false) @map("is_milestone")

  @@unique([entityType, entityId, version])
  @@index([entityType, entityId])
  @@map("version_history")
}

// ============================================
// MODULE 8: Global Settings Panel (Enhanced)
// ============================================

model GlobalSettings {
  id                  String   @id @default(cuid())
  siteTitle           String   @default("My Portfolio") @map("site_title")
  siteTagline         String?  @map("site_tagline")
  metaDescription     String?  @map("meta_description")
  metaKeywords        String?  @map("meta_keywords")
  ogImage             String?  @map("og_image")
  twitterCardType     String   @default("summary_large_image") @map("twitter_card_type")
  defaultLanguage     String   @default("en") @map("default_language")
  locale              String   @default("en-US") @map("locale")
  customCss           String?  @map("custom_css")
  favicon             String?
  appleTouchIcon      String?  @map("apple_touch_icon")
  maintenanceMode     Boolean  @default(false) @map("maintenance_mode")
  analyticsEnabled    Boolean  @default(true) @map("analytics_enabled")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("global_settings")
}

// ============================================
// MODULE 9: File Library and Media Management
// ============================================

model MediaFolder {
  id          String       @id @default(cuid())
  name        String
  parentId    String?      @map("parent_id")
  parent      MediaFolder? @relation("FolderHierarchy", fields: [parentId], references: [id])
  children    MediaFolder[] @relation("FolderHierarchy")
  files       MediaFile[]
  order       Int          @default(0)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  @@map("media_folders")
}

model MediaFile {
  id          String     @id @default(cuid())
  name        String
  originalName String    @map("original_name")
  mimeType    String     @map("mime_type")
  size        Int
  url         String
  thumbnailUrl String?   @map("thumbnail_url")
  width       Int?
  height      Int?
  folderId    String?    @map("folder_id")
  folder      MediaFolder? @relation(fields: [folderId], references: [id])
  tags        String?    // Comma-separated tags
  altText     String?    @map("alt_text")
  isOptimized Boolean   @default(false) @map("is_optimized")
  usageCount  Int        @default(0) @map("usage_count")
  uploadedBy  String?    @map("uploaded_by")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  @@index([folderId])
  @@index([mimeType])
  @@map("media_files")
}

// ============================================
// MODULE 10: Role-Based Permissions System (Enhanced)
// ============================================

model Permission {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  category    String       // system, content, analytics, ai, settings
  users       UserPermission[]
  roles       RolePermission[]
  createdAt   DateTime     @default(now()) @map("created_at")

  @@map("permissions")
}

model Role {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  color       String       @default("#6b7280")
  isDefault   Boolean      @default(false) @map("is_default")
  isSystem    Boolean      @default(false) @map("is_system")
  permissions RolePermission[]
  users       User[]
  invitations Invitation[]
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  @@map("roles")
}

model UserPermission {
  id            String     @id @default(cuid())
  userId        String     @map("user_id")
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permissionId  String     @map("permission_id")
  permission    Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  grantedBy     String?    @map("granted_by")
  expiresAt     DateTime?  @map("expires_at")
  createdAt     DateTime   @default(now()) @map("created_at")

  @@unique([userId, permissionId])
  @@map("user_permissions")
}

model RolePermission {
  id            String     @id @default(cuid())
  roleId        String     @map("role_id")
  role          Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId  String     @map("permission_id")
  permission    Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt     DateTime   @default(now()) @map("created_at")

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model Invitation {
  id          String    @id @default(cuid())
  email       String    @unique
  roleId      String    @map("role_id")
  role        Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)
  token       String    @unique
  status      String    @default("pending") // pending, accepted, expired
  expiresAt   DateTime  @map("expires_at")
  invitedBy   String?   @map("invited_by")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("invitations")
}

model TwoFactorAuth {
  id          String   @id @default(cuid())
  userId      String   @unique @map("user_id")
  secret      String
  backupCodes String   // Encrypted backup codes
  enabledAt   DateTime @default(now()) @map("enabled_at")

  @@map("two_factor_auth")
}
